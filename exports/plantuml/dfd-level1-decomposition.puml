@startuml DFD_Level1_Functional_Decomposition

skinparam backgroundColor #F0F4FF
skinparam defaultFontName Arial
skinparam defaultFontSize 11

skinparam rectangle {
  BackgroundColor #1E3A8A
  FontColor white
  BorderColor #3B82F6
  BorderThickness 2
  RoundCorner 6
}

skinparam usecase {
  BackgroundColor #14532D
  FontColor white
  BorderColor #16A34A
  BorderThickness 2
}

skinparam database {
  BackgroundColor #FEF3C7
  FontColor #78350F
  BorderColor #D97706
  BorderThickness 2
}

skinparam arrow {
  Color #4B5563
  FontColor #1E293B
  FontSize 9
}

skinparam note {
  BackgroundColor white
  BorderColor #D1D5DB
  FontSize 10
}

title <b>DFD Level 1 — Functional Decomposition</b>\nAll Sub-Systems · Yourdon-Coad + Gane-Sarson Data Stores

' ═══ External Entities ═══
rectangle "STUDENT\n<size:9>External Entity</size>" as STUDENT
rectangle "FACULTY\n<size:9>External Entity</size>" as FACULTY  #4C1D95##7C3AED
rectangle "HOD\n<size:9>External Entity</size>" as HOD          #065F46##059669
rectangle "ADMIN\n<size:9>External Entity</size>" as ADMIN      #7C2D12##EA580C

' ═══ Processes ═══
usecase "**1.0**\nAuthentication\n& Session" as P1
usecase "**2.0**\nFeedback\nCollection" as P2
usecase "**3.0**\nForm Template\nManagement" as P3
usecase "**4.0**\nAnalytics &\nReporting" as P4
usecase "**5.0**\nInstitution\nManagement" as P5

' ═══ Data Stores (Gane-Sarson style) ═══
database "D1 | Feedback" as D1
database "D2 | Courses" as D2
database "D3 | Faculty" as D3
database "D4 | Departments" as D4
database "D5 | Form Templates" as D5
database "D6 | Feedback Windows" as D6

' ═══ External ↔ Process Flows ═══

' STUDENT ↔ P1 Auth
STUDENT --> P1 : Login Credentials
P1 --> STUDENT : Auth Token / Session

' STUDENT ↔ P2 Feedback
STUDENT --> P2 : Feedback Submission
P2 --> STUDENT : Ref ID / Confirmation

' FACULTY ↔ P1
FACULTY --> P1 : Login Credentials
P1 --> FACULTY : Auth Token

' FACULTY ← P4 Analytics
P4 --> FACULTY : Performance Analytics

' HOD ↔ P3 Form Template
HOD --> P3 : Form Config Request
P3 --> HOD : Template Saved Confirmation

' HOD ← P4 Analytics
P4 --> HOD : Dept Analytics / PDF Report

' ADMIN ↔ P5 Institution
ADMIN --> P5 : Management Request
P5 --> ADMIN : System Dashboard

' ═══ Process ↔ Process Flows ═══
P1 --> P2 : Auth Validated (Token)
P1 --> P5 : Admin Auth Validated
P3 --> P2 : Form Template Applied
P2 --> P4 : Feedback Data Aggregated
P4 --> P5 : Cross-Dept Summary

' ═══ Process ↔ Data Store Flows ═══

' P2 ↔ D1 Feedback
P2 --> D1 : Store Feedback Record
D1 --> P2 : Feedback Records Read

' P2 ↔ D2 Courses
D2 --> P2 : Course & Faculty Info
P2 --> D2 : Course Lookup

' P2 ↔ D6 Feedback Windows
D6 --> P2 : Window Status
P2 --> D6 : Window Query

' P3 ↔ D5 Form Templates
P3 --> D5 : Save / Update Template
D5 --> P3 : Load Template

' P4 ↔ D1,D2,D3,D4
D1 --> P4 : Read All Feedback
D2 --> P4 : Read Courses
D3 --> P4 : Read Faculty Info
D4 --> P4 : Read Departments

' P5 ↔ D2,D3,D4
P5 --> D2 : Manage Courses
P5 --> D3 : Manage Faculty
P5 --> D4 : Manage Departments

note bottom of D1
  All data stores represent
  PostgreSQL database tables
end note

legend right
  |= Symbol    |= Meaning                     |
  | Rectangle  | External Entity               |
  | Oval       | Process                       |
  | Cylinder   | Data Store (Gane-Sarson)      |
  | Arrow →    | Data Flow                     |
  Yourdon-Coad + Gane-Sarson Notation
endlegend

@enduml
