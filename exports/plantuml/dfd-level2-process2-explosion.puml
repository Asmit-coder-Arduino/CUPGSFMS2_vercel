@startuml DFD_Level2_Process2_Explosion

skinparam backgroundColor #F0F9FF
skinparam defaultFontName Arial
skinparam defaultFontSize 11

skinparam rectangle {
  BackgroundColor #1E3A8A
  FontColor white
  BorderColor #3B82F6
  BorderThickness 2
  RoundCorner 6
}

skinparam usecase {
  BackgroundColor #14532D
  FontColor white
  BorderColor #16A34A
  BorderThickness 2
}

skinparam database {
  BackgroundColor #FEF3C7
  FontColor #78350F
  BorderColor #D97706
  BorderThickness 2
}

skinparam arrow {
  Color #4B5563
  FontColor #1E293B
  FontSize 9
}

skinparam package {
  BackgroundColor #EFF6FF
  BorderColor #0284C7
  BorderThickness 2
  FontColor #0C4A6E
  FontSize 11
}

skinparam note {
  BackgroundColor white
  BorderColor #D1D5DB
  FontSize 10
}

title <b>DFD Level 2 — Process 2.0 Explosion</b>\nFeedback Collection Sub-Processes · Yourdon-Coad Notation

' ═══ External Interfaces (outside P2 boundary) ═══
rectangle "STUDENT\n<size:9>input source</size>" as STUDENT
rectangle "HOD FORM\n<size:9>Template Source</size>" as HOD_FORM  #065F46##059669

' ═══ Explosion Package — Process 2.0 Boundary ═══
package "Process 2.0 — Feedback Collection (Expanded)" {

  usecase "**2.1**\nValidate\nInputs" as P21

  usecase "**2.2**\nCheck Window\nAvailability" as P22

  usecase "**2.3**\nProfanity\nFilter" as P23

  usecase "**2.4**\nCourse-Faculty\nIntegrity Check" as P24

  usecase "**2.5**\nGenerate\nReference ID" as P25

  usecase "**2.6**\nStore\nFeedback Record" as P26

}

' ═══ Data Stores (Gane-Sarson) ═══
database "D1 | Feedback" as D1
database "D2 | Courses" as D2
database "D3 | Faculty" as D3
database "D6 | Feedback Windows" as D6

' ═══ External → P21 ═══
STUDENT  --> P21 : Raw Feedback Data\n(ratings, comments, course)
HOD_FORM --> P21 : Custom Form Template\n(custom question fields)

' ═══ P21 Internal Routing ═══
P21 --> P22 : Trigger Window Check
P22 --> P21 : Window Open / Closed Status

P21 --> P23 : Validated Field Values

' ═══ P23 → P24 ═══
P23 --> P24 : Filtered Text Content\n(profanity-free)

P24 --> P25 : Integrity Passed\n(course+faculty verified)

' ═══ P22 Routing when window open ═══
P22 --> P25 : Window Status OK →\nProceed

' ═══ P25 → P26 ═══
P25 --> P26 : Stamped Feedback Record\n+ Reference ID

' ═══ Confirm Back to Student ═══
P26 --> P21 : Store Confirmed
P21 --> STUDENT : Confirmation +\nReference ID

' ═══ P24 ↔ Data Stores (integrity lookup) ═══
D2 --> P24 : Course Record\n(code, name, dept, credits)
D3 --> P24 : Faculty Record\n(employee_id, name, dept)

' ═══ P22 ↔ D6 ═══
D6 --> P22 : Window Record\n(start/end date, is_active)
P22 --> D6 : Window Query

' ═══ P26 → D1 ═══
P26 --> D1 : Store Feedback Record\n(all fields + reference_id)

note right of P21
  **2.1 Validates:**
  • All required fields present
  • Rating range: 0.5 – 5.0
  • Student year/section format
  • Academic year format
end note

note right of P24
  **2.4 Checks:**
  • Course belongs to selected dept
  • Faculty assigned to that course
  • If unassigned → faculty_id = null
  • Prevents cross-dept manipulation
end note

note right of P25
  **2.5 Generates:**
  • Format: FB-YYYYMMDD-XXXXXX
  • Cryptographically unique
  • Used for anonymous tracking
end note

legend right
  |= Symbol   |= Meaning                |
  | Rectangle | External Interface       |
  | Oval      | Sub-Process             |
  | Cylinder  | Data Store              |
  | Package   | P2.0 Explosion Boundary |
  | Arrow →   | Data Flow               |
  Yourdon-Coad Notation
endlegend

@enduml
