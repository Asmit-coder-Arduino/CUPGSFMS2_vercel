@startuml DFD_Level0_Context

!define EXTERNAL_COLOR #1E3A8A
!define PROCESS_COLOR  #14532D
!define FLOW_COLOR     #4B5563

skinparam backgroundColor #F0F4FF
skinparam defaultFontName Arial
skinparam defaultFontSize 12

skinparam rectangle {
  BackgroundColor EXTERNAL_COLOR
  FontColor white
  BorderColor #3B82F6
  BorderThickness 2
  RoundCorner 8
}

skinparam usecase {
  BackgroundColor PROCESS_COLOR
  FontColor white
  BorderColor #16A34A
  BorderThickness 2
}

skinparam arrow {
  Color FLOW_COLOR
  FontColor #1E293B
  FontSize 10
}

skinparam note {
  BackgroundColor white
  BorderColor #D1D5DB
}

title <b>DFD Level 0 — Context Diagram</b>\nCUPGS Academic Feedback Management System · Yourdon-Coad Notation

' ── External Entities ──
rectangle "STUDENT\n<size:9>External Entity</size>" as STUDENT
rectangle "HOD\n<size:9>External Entity</size>" as HOD  #065F46##059669
rectangle "ADMIN\n<size:9>External Entity</size>" as ADMIN  #7C2D12##EA580C
rectangle "FACULTY\n<size:9>External Entity</size>" as FACULTY  #4C1D95##7C3AED

' ── Central Process ──
usecase "**Process 0.**\nCUPGS Feedback\nManagement System" as P0

' ── Positioning hints ──
STUDENT -[hidden]d- P0
HOD     -[hidden]l- P0
ADMIN   -[hidden]u- P0
FACULTY -[hidden]r- P0

' ── Data Flows ──
STUDENT --> P0 : Feedback Submission
P0 --> STUDENT : Submission Confirmation

HOD --> P0 : Form Template Config
P0 --> HOD : Analytics Report / PDF

ADMIN --> P0 : Dept / Course Config
P0 --> ADMIN : Institution Dashboard

FACULTY --> P0 : View Request / Login
P0 --> FACULTY : Performance Analytics

note bottom of P0
  **System Boundary**
  Single process represents entire
  CUPGS Feedback Management System
end note

legend right
  |= Symbol         |= Meaning          |
  | Rectangle       | External Entity   |
  | Oval (circle)   | Process           |
  | Arrow           | Data Flow         |
  Yourdon-Coad Notation
endlegend

@enduml
